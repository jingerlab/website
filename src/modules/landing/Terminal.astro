---
// src/components/Terminal.astro
---

<section class="py-24 bg-background relative overflow-hidden">
  <div class="container mx-auto px-6 max-w-6xl">
    <div id="terminal-window" class="w-full bg-white dark:bg-zinc-950 rounded-xl border border-zinc-200 dark:border-zinc-800 shadow-2xl overflow-hidden font-mono flex flex-col min-h-[650px] transition-all duration-500">
      
      <div class="bg-zinc-50 dark:bg-zinc-900/50 px-4 py-3 flex items-center justify-between border-b border-zinc-200 dark:border-zinc-800">
        <div id="window-controls" class="flex gap-3 pl-2">
          <div class="dot w-3 h-3 rounded-full bg-[#FF5F56] shadow-sm"></div>
          <div class="dot w-3 h-3 rounded-full bg-[#FFBD2E] shadow-sm"></div>
          <div class="dot w-3 h-3 rounded-full bg-[#27C93F] shadow-sm"></div>
        </div>
        <span class="text-[10px] text-zinc-400 dark:text-zinc-500 uppercase tracking-[0.2em] font-bold italic">jingerlab_os // stable_graphite_v30.jl</span>
        <div class="w-12"></div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 flex-grow min-h-[500px]">
        <div class="p-8 border-b lg:border-b-0 lg:border-r border-zinc-100 dark:border-zinc-900 flex flex-col justify-between">
          <div class="space-y-6">
            <p class="text-blue-500 font-bold italic text-[10px] tracking-widest">// CORE_CALIBRATION: GRAPHITE_LOCKED</p>
            
            <div class="space-y-4">
              <p class="text-zinc-800 dark:text-zinc-200 text-lg font-bold"><span class="text-blue-600 font-bold">const</span> MATERIAL = "Solid_Graphite"</p>
              
              <div class="pl-4 border-l-2 border-zinc-200 dark:border-zinc-800 space-y-4 font-mono text-[11px]">
                <p><span class="text-zinc-500 font-bold">GRAY_SCALE:</span> Stable Zinc-800 / Zinc-300</p>
                <p><span class="text-zinc-500 font-bold">GRID:</span> Laser-Etched Meridians</p>
                <p><span class="text-cyan-400 font-bold">HARDWARE:</span> Cyan Geometric Constellation</p>
              </div>
            </div>
          </div>


        <div class="p-4 bg-zinc-100/50 dark:bg-zinc-900/50 rounded-lg border border-zinc-100 dark:border-zinc-800 space-y-3">
          <p class="text-[9px] text-zinc-400 font-bold uppercase tracking-widest italic mb-1">Global Constellation Key:</p>
          <div class="grid grid-cols-2 gap-x-4 gap-y-2 text-[9px] font-mono font-bold">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full" style="background: #ff007f"></span>
              <span class="text-zinc-600 dark:text-zinc-400">N. AMERICA</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full" style="background: #ff5f1f"></span>
              <span class="text-zinc-600 dark:text-zinc-400">S. AMERICA</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full" style="background: #00ffff"></span>
              <span class="text-zinc-600 dark:text-zinc-400">EUROPE</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full" style="background: #39ff14"></span>
              <span class="text-zinc-600 dark:text-zinc-400">AFRICA</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full" style="background: #ffbf00"></span>
              <span class="text-zinc-600 dark:text-zinc-400">ASIA</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full" style="background: #bc13fe"></span>
              <span class="text-zinc-600 dark:text-zinc-400">OCEANIA</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full" style="background: #ffffff"></span>
              <span class="text-zinc-600 dark:text-zinc-400">ANTARCTICA</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full border border-zinc-400" style="background: #a1a1aa"></span>
              <span class="text-zinc-600 dark:text-zinc-400">SILVER_POLES</span>
            </div>
          </div>
        </div>
        </div>

        <div class="relative flex items-center justify-center bg-zinc-100/30 dark:bg-black/50 min-h-[500px] overflow-hidden">
          <canvas id="graphite-canvas" width="800" height="800" style="width: 400px !important; height: 400px !important;" class="pointer-events-none"></canvas>
        </div>
      </div>

      <div class="bg-zinc-50 dark:bg-emerald-950/10 px-6 py-2 border-t border-zinc-200 dark:border-zinc-900 text-[10px] flex justify-between items-center font-bold">
        <span class="text-emerald-600 dark:text-emerald-500 tracking-widest animate-pulse uppercase">● Laboratory_Environment_Active</span>
        <span class="text-zinc-400 dark:text-zinc-500 font-mono tracking-tighter italic italic">HARSH JINGER // 23.5° INCLINATION</span>
      </div>
    </div>
  </div>
</section>

<script>
  function initGraphiteLab() {
    const canvas = document.getElementById('graphite-canvas') as HTMLCanvasElement;
    const dots = document.querySelectorAll('.dot');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let rotation = 0;
    const tilt = 23.5 * (Math.PI / 180);


  const capitals = [
      // --- NORTH AMERICA (#ff007f - Pink) ---
      { lat: 40.7, lon: -74.0, c: '#ff007f' },   // New York
      { lat: 34.0, lon: -118.2, c: '#ff007f' },  // Los Angeles
      { lat: 19.4, lon: -99.1, c: '#ff007f' },   // Mexico City
      { lat: 45.4, lon: -75.7, c: '#ff007f' },   // Ottawa
      { lat: 25.7, lon: -80.1, c: '#ff007f' },   // Miami
      { lat: 47.6, lon: -122.3, c: '#ff007f' },  // Seattle
      { lat: 14.6, lon: -90.5, c: '#ff007f' },   // Guatemala City
      { lat: 51.0, lon: -114.0, c: '#ff007f' },  // Calgary

      // --- SOUTH AMERICA (#ff5f1f - Neon Orange) ---
      { lat: -34.6, lon: -58.4, c: '#ff5f1f' },  // Buenos Aires
      { lat: -15.8, lon: -47.9, c: '#ff5f1f' },  // Brasilia
      { lat: -12.0, lon: -77.0, c: '#ff5f1f' },  // Lima
      { lat: -33.4, lon: -70.6, c: '#ff5f1f' },  // Santiago
      { lat: 4.7, lon: -74.0, c: '#ff5f1f' },    // Bogotá
      { lat: -0.2, lon: -78.4, c: '#ff5f1f' },   // Quito
      { lat: -23.5, lon: -46.6, c: '#ff5f1f' },  // São Paulo
      { lat: 10.5, lon: -66.9, c: '#ff5f1f' },   // Caracas

      // --- EUROPE (#00ffff - Electric Cyan) ---
      { lat: 51.5, lon: -0.1, c: '#00ffff' },    // London
      { lat: 48.8, lon: 2.3, c: '#00ffff' },     // Paris
      { lat: 52.5, lon: 13.4, c: '#00ffff' },    // Berlin
      { lat: 41.9, lon: 12.5, c: '#00ffff' },    // Rome
      { lat: 59.3, lon: 18.0, c: '#00ffff' },    // Stockholm
      { lat: 60.1, lon: 24.9, c: '#00ffff' },    // Helsinki
      { lat: 50.8, lon: 4.3, c: '#00ffff' },     // Brussels
      { lat: 40.4, lon: -3.7, c: '#00ffff' },    // Madrid
      { lat: 55.7, lon: 37.6, c: '#00ffff' },    // Moscow
      { lat: 47.3, lon: 8.5, c: '#00ffff' },     // Zurich
      { lat: 52.2, lon: 21.0, c: '#00ffff' },    // Warsaw

      // --- AFRICA (#39ff14 - Neon Green) ---
      { lat: 30.0, lon: 31.2, c: '#39ff14' },    // Cairo
      { lat: -33.9, lon: 18.4, c: '#39ff14' },   // Cape Town
      { lat: 9.0, lon: 38.7, c: '#39ff14' },     // Addis Ababa
      { lat: -1.3, lon: 36.8, c: '#39ff14' },    // Nairobi
      { lat: 6.5, lon: 3.4, c: '#39ff14' },      // Lagos
      { lat: 33.5, lon: -7.5, c: '#39ff14' },    // Casablanca
      { lat: -15.3, lon: 28.2, c: '#39ff14' },   // Lusaka
      { lat: -26.2, lon: 28.0, c: '#39ff14' },   // Johannesburg
      { lat: 12.6, lon: -8.0, c: '#39ff14' },    // Bamako
      { lat: -4.3, lon: 15.2, c: '#39ff14' },    // Kinshasa

      // --- ASIA (#ffbf00 - Amber) ---
      { lat: 35.6, lon: 139.6, c: '#ffbf00' },   // Tokyo
      { lat: 28.6, lon: 77.2, c: '#ffbf00' },    // New Delhi
      { lat: 39.9, lon: 116.4, c: '#ffbf00' },   // Beijing
      { lat: 1.3, lon: 103.8, c: '#ffbf00' },    // Singapore
      { lat: 25.2, lon: 55.3, c: '#ffbf00' },    // Dubai
      { lat: 31.2, lon: 121.4, c: '#ffbf00' },   // Shanghai
      { lat: 13.7, lon: 100.5, c: '#ffbf00' },   // Bangkok
      { lat: 37.5, lon: 126.9, c: '#ffbf00' },   // Seoul
      { lat: 21.0, lon: 105.8, c: '#ffbf00' },   // Hanoi
      { lat: 24.7, lon: 46.6, c: '#ffbf00' },    // Riyadh
      { lat: 6.9, lon: 79.8, c: '#ffbf00' },     // Colombo
      { lat: 12.9, lon: 77.5, c: '#ffbf00' },    // Bengaluru

      // --- AUSTRALIA/OCEANIA (#bc13fe - Neon Purple) ---
      { lat: -35.3, lon: 149.1, c: '#bc13fe' },  // Canberra
      { lat: -37.8, lon: 144.9, c: '#bc13fe' },  // Melbourne
      { lat: -33.8, lon: 151.2, c: '#bc13fe' },  // Sydney
      { lat: -31.9, lon: 115.8, c: '#bc13fe' },  // Perth
      { lat: -36.8, lon: 174.7, c: '#bc13fe' },  // Auckland
      { lat: -41.2, lon: 174.7, c: '#bc13fe' },  // Wellington
      { lat: -18.1, lon: 178.4, c: '#bc13fe' },  // Suva (Fiji)
      { lat: -9.4, lon: 147.2, c: '#bc13fe' },   // Port Moresby

      // --- ANTARCTICA (#ffffff - Pure White) ---
      { lat: -77.8, lon: 166.6, c: '#ffffff' },  // McMurdo Station
      { lat: -90.0, lon: 0.0, c: '#ffffff' },    // Amundsen–Scott (South Pole)
      { lat: -62.2, lon: -58.9, c: '#ffffff' },  // King George Island
      { lat: -70.6, lon: 8.2, c: '#ffffff' },    // Neumayer Station
      { lat: -66.2, lon: 110.5, c: '#ffffff' }   // Casey Station
    ].map(n => ({ 
      lat: n.lat * (Math.PI/180), 
      lon: n.lon * (Math.PI/180), 
      color: n.c 
    }));



    function getCoords(lat: number, lon: number, r: number, currentRot: number, isPolar = false) {
      let x0, y0, z0;
      if (isPolar) {
        x0 = r * Math.sin(currentRot);
        y0 = r * Math.cos(currentRot);
        z0 = 0;
      } else {
        x0 = r * Math.cos(lat) * Math.sin(lon + currentRot);
        y0 = r * Math.sin(lat);
        z0 = r * Math.cos(lat) * Math.cos(lon + currentRot);
      }
      const xt = x0 * Math.cos(tilt) - y0 * Math.sin(tilt);
      const yt = x0 * Math.sin(tilt) + y0 * Math.cos(tilt);
      const s = 1200 / (1200 + z0);
      return { x: xt * s + 400, y: -yt * s + 400, z: z0, scale: s };
    }

    function drawSat(p: any, isCube: boolean) {
      ctx!.fillStyle = '#22d3ee';
      ctx!.globalAlpha = (p.z + 400) / 800;
      const size = 6.5 * p.scale;
      if (isCube) {
        ctx!.fillRect(p.x - size, p.y - size, size * 2, size * 2);
      } else {
        ctx!.beginPath();
        ctx!.ellipse(p.x, p.y, size, size * 1.5, rotation, 0, Math.PI * 2);
        ctx!.fill();
      }
    }

    function render() {
      ctx!.clearRect(0, 0, 800, 800);
      rotation += 0.007;
      const r = 260;
      const isDark = document.documentElement.classList.contains('dark');

      // 1. STABLE SOLID CORE (Graphite/Zinc Gray)
      ctx!.fillStyle = isDark ? '#27272a' : '#d4d4d8';
      ctx!.beginPath(); ctx!.arc(400, 400, r, 0, Math.PI * 2); ctx!.fill();
      
      // 2. GRID ETCHING
      ctx!.strokeStyle = isDark ? 'rgba(255,255,255,0.3)' : 'rgba(0,0,0,0.2)';
      ctx!.lineWidth = 1.2;

      // Latitude
      [0, 0.4, -0.4, 1.1, -1.1].forEach(lt => {
        ctx!.beginPath();
        for(let i=0; i<=90; i++) {
          const p = getCoords(lt, (i/90)*Math.PI * 2, r, rotation);
          if (p.z > 0) i === 0 ? ctx!.moveTo(p.x, p.y) : ctx!.lineTo(p.x, p.y);
        }
        ctx!.stroke();
      });

      // Longitude
      [0, Math.PI/4, Math.PI/2, 3*Math.PI/4, Math.PI, -Math.PI/4, -Math.PI/2, -3*Math.PI/4].forEach(ln => {
        ctx!.beginPath();
        for(let i=0; i<=90; i++) {
          const p = getCoords((i/90)*Math.PI - Math.PI/2, ln, r, rotation);
          if (p.z > 0) i === 0 ? ctx!.moveTo(p.x, p.y) : ctx!.lineTo(p.x, p.y);
        }
        ctx!.stroke();
      });

      // 3. SILVER POLES (23.5° Axis)
      [Math.PI/2, -Math.PI/2].forEach(pLat => {
        const p = getCoords(pLat, 0, r, 0);
        ctx!.fillStyle = isDark ? '#a1a1aa' : '#71717a';
        ctx!.beginPath(); ctx!.arc(p.x, p.y, 9 * p.scale, 0, Math.PI * 2); ctx!.fill();
      });

      // 4. CAPITALS
      capitals.forEach(n => {
        const p = getCoords(n.lat, n.lon, r, rotation);
        if (p.z > -100) {
          ctx!.globalAlpha = (p.z + r) / (2 * r);
          ctx!.fillStyle = n.color;
          ctx!.beginPath(); ctx!.arc(p.x, p.y, 4.5 * p.scale, 0, Math.PI * 2); ctx!.fill();
        }
      });

      // 5. UNIFIED CYAN SATS (Hardware)
      drawSat(getCoords(0, 0, 310, rotation * 1.5, true), false); // Polar Cyl
      drawSat(getCoords(0, rotation * 0.8, 350, 0), true);        // Equatorial Cube
      drawSat(getCoords(0.2, rotation * 0.4, 400, 0), false);     // Geosync Cyl

      requestAnimationFrame(render);
    }
    render();
  }

  document.addEventListener('astro:page-load', initGraphiteLab);
  if (document.readyState === 'complete') initGraphiteLab();
  else window.addEventListener('load', initGraphiteLab);
</script>
