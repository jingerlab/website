---
import { ArrowLeft, ArrowDown, ArrowRight } from "lucide-react";
---

<div id="transition-circle" class="fixed inset-0 pointer-events-none z-[999] flex items-center justify-center">
  <div class="w-0 h-0 border border-primary/20 rounded-full transition-all duration-1000 ease-in-out opacity-0"></div>
</div>

<section class="relative min-h-screen md:h-screen flex flex-col items-center justify-start overflow-hidden border-b border-border/50 bg-background px-6 md:px-16 lg:px-24 pt-12 md:pt-16">
  
  <div class="w-full flex flex-col md:flex-row items-stretch justify-center gap-12 md:gap-20 flex-grow">
    
    <div class="flex-1 flex flex-col relative z-20 max-w-2xl min-h-full py-4 md:py-8">
      <div class="space-y-4 text-left text-foreground">
        <p class="reveal-text font-sans font-bold uppercase tracking-[0.3em] text-[9px] text-primary/70" style="transition-delay: 100ms;">
          Systems Research // Lab 01
        </p>
        <h1 class="reveal-text text-5xl md:text-7xl font-display leading-[0.95] tracking-tighter" style="transition-delay: 300ms;">
          An open-ended, <br/>
          <span class="italic text-muted-foreground font-serif text-foreground/60">interdisciplinary</span> lab
        </h1>
        <p class="reveal-text font-serif text-xl text-foreground/60 italic" style="transition-delay: 500ms;">by Harsh Jinger</p>
      </div>

      <div class="flex-grow"></div>

      <div class="max-w-md text-left mb-4">
        <p id="typewriter-quote" class="font-serif italic text-lg text-muted-foreground/80 leading-relaxed min-h-[1.5em]"></p>
      </div>
    </div>

    <div class="flex-1 relative flex items-start justify-center py-4 md:py-8">
      <div id="interactive-panel" class="relative w-full aspect-square md:max-h-[55vh] bg-background/50 overflow-hidden border border-border/40 shadow-2xl group cursor-crosshair">
        <div id="rotating-svg" class="absolute w-[400%] h-[400%] pointer-events-none"
          style="background-image: url('/penrose.svg'); background-size: contain; background-repeat: no-repeat; background-position: center; top: -150%; left: -150%; transform: rotate(0deg); transform-origin: 47.5% 52.5%;">
        </div>

        <div id="explanation-note" class="absolute bottom-0 left-0 w-full p-6 bg-background/95 backdrop-blur-xl border-t border-primary/20 opacity-0 z-[100] transition-all duration-500 ease-out pointer-events-none" style="transform: translateY(100%);">
          <p class="font-sans font-bold text-[8px] uppercase tracking-widest text-primary mb-1">Theoretical Context</p>
          <p class="font-serif text-[11px] italic leading-relaxed text-muted-foreground">
            Aperiodic Penrose Tiling: A structural "hiccup"—maintaining perfect order without repetition, mimicking the interdisciplinary bridge between private thought and public contribution.
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="w-full max-w-7xl mt-auto py-8 md:py-12">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6 relative z-50">
      
      {['archives', 'lab', 'teaching'].map((key) => {
        const icons = { archives: ArrowLeft, lab: ArrowDown, teaching: ArrowRight };
        const Icon = icons[key as keyof typeof icons];
        
        const config = {
          archives: { order: 'order-1', dir: 'left', origin: 'origin-right', anim: 'group-hover:animate-move-left' },
          teaching: { order: 'order-2 md:order-3', dir: 'right', origin: 'origin-left', anim: 'group-hover:animate-move-right' },
          lab: { order: 'order-3 md:order-2 col-span-2 md:col-span-1', dir: 'down', origin: 'origin-top', anim: 'group-hover:animate-move-down' }
        }[key as keyof typeof icons];
        
        return (
          <a href={`/${key}`} data-direction={config.dir} 
             class={`nav-btn group relative overflow-hidden flex items-center justify-center gap-4 font-sans font-bold uppercase tracking-[0.3em] text-[10px] 
             border-2 border-border/80 px-6 py-8 transition-all duration-500 
             bg-white dark:bg-zinc-900/50 
             shadow-[0_25px_50px_-12px_rgba(0,0,0,0.2)] dark:shadow-none 
             hover:text-background dark:hover:text-zinc-100 active:scale-[0.95] ${config.order}`}>
            
            <span class={`absolute inset-0 bg-foreground dark:bg-zinc-800 transition-transform duration-500 ease-out scale-x-0 scale-y-0 ${config.origin} group-hover:scale-x-100 group-hover:scale-y-100`}></span>
            
            <span class="absolute top-0 left-0 w-full h-[1px] bg-primary/40 -translate-x-full group-hover:animate-scan-fast"></span>
            <span class="absolute bottom-0 right-0 w-full h-[1px] bg-primary/40 translate-x-full group-hover:animate-scan-fast"></span>

            <div class="relative z-10 flex items-center gap-3 transition-colors duration-300">
              {key === 'archives' && <Icon className={`w-4 h-4 ${config.anim}`} />}
              <span>{key}</span>
              {key !== 'archives' && <Icon className={`w-4 h-4 ${config.anim}`} />}
            </div>
          </a>
        )
      })}

    </div>
  </div>
</section>

<style is:global>
  /* Added text entrance animations */
  .reveal-text {
    opacity: 0;
    filter: blur(10px);
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-text.active {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }

  /* Added typewriter cursor */
  #typewriter-quote::after {
    content: '|';
    animation: blink 1s step-end infinite;
    color: var(--primary);
  }

  @keyframes blink { 50% { opacity: 0; } }
  @keyframes scan-fast { from { transform: translateX(-100%); } to { transform: translateX(100%); } }
  @keyframes move-left { 0%, 100% { transform: translateX(0); } 50% { transform: translateX(-8px); } }
  @keyframes move-right { 0%, 100% { transform: translateX(0); } 50% { transform: translateX(8px); } }
  @keyframes move-down { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(8px); } }

  .animate-scan-fast { animation: scan-fast 0.5s linear infinite; }
  .group-hover\:animate-move-left { animation: move-left 0.6s ease-in-out infinite; }
  .group-hover\:animate-move-right { animation: move-right 0.6s ease-in-out infinite; }
  .group-hover\:animate-move-down { animation: move-down 0.6s ease-in-out infinite; }

  ::view-transition-old(root), ::view-transition-new(root) {
    animation-duration: 1.2s;
    animation-timing-function: cubic-bezier(0.85, 0, 0.15, 1);
  }
</style>

<script>
  const initLabInteraction = () => {
    // 1. Trigger Entrance Animations
    const reveals = document.querySelectorAll('.reveal-text');
    setTimeout(() => {
      reveals.forEach(el => el.classList.add('active'));
    }, 100);

    // 2. Typewriter Transition for Blockquote
    const quoteElement = document.getElementById('typewriter-quote');
    const quoteText = 'a hiccup in the continuum of knowledge...';
    let charIndex = 0;
    
    if (quoteElement) {
      quoteElement.innerHTML = '';
      const type = () => {
        if (charIndex < quoteText.length) {
          quoteElement.innerHTML += quoteText.charAt(charIndex);
          charIndex++;
          setTimeout(type, 60); 
        }
      };
      setTimeout(type, 1200); // Start typing after headers reveal
    }

    // 3. Existing Panel Logic
    const panel = document.getElementById('interactive-panel');
    const svg = document.getElementById('rotating-svg');
    const note = document.getElementById('explanation-note');
    const navButtons = document.querySelectorAll('.nav-btn');
    
    if (!panel || !svg || !note) return;

    let currentRotation = 0;
    let targetSpeed = 0.15; 
    let currentSpeed = 0.15;

    const animate = () => {
      currentSpeed += (targetSpeed - currentSpeed) * 0.05;
      currentRotation += currentSpeed;
      svg.style.transform = `rotate(${currentRotation}deg)`;
      requestAnimationFrame(animate);
    };

    const damp = () => { targetSpeed = 0.08; note.style.opacity = '1'; note.style.transform = 'translateY(0)'; };
    const resume = () => { targetSpeed = 0.15; note.style.opacity = '0'; note.style.transform = 'translateY(100%)'; };

    panel.addEventListener('mouseenter', damp);
    panel.addEventListener('mouseleave', resume);
    panel.addEventListener('touchstart', damp, {passive: true});

    requestAnimationFrame(animate);

    navButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const direction = btn.getAttribute('data-direction');
        document.documentElement.className = `slide-${direction}`;
      });
    });
  };

  initLabInteraction();
  document.addEventListener('astro:after-swap', initLabInteraction);
</script>
