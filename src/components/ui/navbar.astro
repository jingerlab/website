---
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Search, Sun, Moon, Menu, X } from "lucide-react";
---

<nav class="sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur-md transition-colors duration-500 supports-[backdrop-filter]:bg-background/60">
  <div class="container flex h-16 items-center justify-between mx-auto px-4">
    
    <div class="flex items-center gap-8">
      <a href="/" id="logo-link" class="group flex items-center space-x-2 transition-transform duration-200 active:rotate-3 active:scale-95">
        <span class="font-display text-4xl tracking-tighter transition-transform duration-300 group-hover:scale-110">
          JingerLab
        </span>
      </a>

      <div class="hidden md:flex items-center gap-6 text-sm font-sans font-medium">
        {['Archives', 'Lab', 'Teaching'].map((item) => (
          <a 
            href={`/${item.toLowerCase()}`} 
            class="relative text-muted-foreground transition-colors hover:text-primary after:absolute after:bottom-[-4px] after:left-0 after:h-[2px] after:w-0 after:bg-primary after:transition-all after:duration-300 hover:after:w-full"
          >
            {item}
          </a>
        ))}
      </div>
    </div>

    <div class="flex items-center justify-end gap-2 sm:gap-4">
      
      <div class="relative hidden sm:flex items-center group font-sans">
        <Search className="absolute left-2.5 h-4 w-4 text-muted-foreground transition-colors group-focus-within:text-primary" />
        <Input 
          type="search" 
          id="nav-search"
          placeholder="Search..." 
          autoComplete="on"
          className="pl-8 w-[120px] md:w-[200px] lg:w-[300px] h-9 bg-muted/20 focus:w-[150px] md:focus:w-[250px] lg:focus:w-[350px] transition-all duration-300" 
        />
        <div id="search-results" class="absolute top-11 left-0 w-full max-h-[400px] bg-background border rounded-md shadow-xl overflow-y-auto hidden z-[60]">
          <div id="results-list" class="p-2 text-sm divide-y divide-border"></div>
        </div>
      </div>

      <Button client:load variant="ghost" size="icon" id="theme-toggle" className="relative h-9 w-9 overflow-hidden focus-visible:ring-0">
        <Sun className="h-5 w-5 rotate-90 scale-0 transition-all duration-500 dark:rotate-0 dark:scale-100" />
        <Moon className="absolute h-5 w-5 rotate-0 scale-100 transition-all duration-500 dark:-rotate-90 dark:scale-0" />
      </Button>

      <Button client:load variant="ghost" size="icon" id="menu-toggle" className="md:hidden h-9 w-9 transition-transform active:scale-90 focus-visible:ring-0">
        <div class="relative h-5 w-5">
          <Menu id="menu-icon-open" className="absolute h-5 w-5 transition-all duration-300" />
          <X id="menu-icon-close" className="absolute h-5 w-5 scale-0 opacity-0 transition-all duration-300" />
        </div>
      </Button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t bg-background transition-all duration-300 ease-in-out">
    <div class="flex flex-col p-4 space-y-4 opacity-0 transition-opacity duration-300" id="mobile-menu-content">
      
      <div class="relative flex flex-col items-center sm:hidden w-full space-y-2">
        <div class="relative w-full font-sans">
            <Search className="absolute left-3 top-3 h-4 w-4 text-muted-foreground" />
            <Input 
              type="search" 
              id="mobile-nav-search"
              placeholder="Search..." 
              className="pl-9 w-full h-10 bg-muted/40 text-sm border-none" 
            />
        </div>
        <div id="mobile-search-results" class="w-full max-h-[300px] bg-background border rounded-md shadow-lg overflow-y-auto hidden">
          <div id="mobile-results-list" class="p-2 text-sm divide-y divide-border"></div>
        </div>
      </div>

      <nav class="flex flex-col space-y-1">
        {['Archives', 'Lab', 'Teaching'].map((item) => (
          <div class="py-2">
            <a 
              href={`/${item.toLowerCase()}`} 
              class="mobile-link relative inline-block text-base font-sans font-medium text-muted-foreground hover:text-primary transition-all after:absolute after:bottom-[-2px] after:left-0 after:h-[2px] after:w-0 after:bg-primary after:transition-all after:duration-300 hover:after:w-full"
            >
              {item}
            </a>
          </div>
        ))}
      </nav>
    </div>
  </div>
</nav>

<style is:global>
  /* Scientific Search Highlights */
  mark {
    background-color: hsl(var(--primary) / 0.2);
    color: hsl(var(--primary));
    font-weight: 600;
    border-radius: 2px;
    padding: 0 1px;
  }
  .dark mark {
    background-color: hsl(var(--primary) / 0.4);
    color: #fff;
  }
</style>

<script is:inline>
  const initNavbar = () => {
    const themeBtn = document.getElementById('theme-toggle');
    const menuBtn = document.getElementById('menu-toggle');
    const menuOverlay = document.getElementById('mobile-menu');
    const menuContent = document.getElementById('mobile-menu-content');
    const openIcon = document.getElementById('menu-icon-open');
    const closeIcon = document.getElementById('menu-icon-close');
    const logoLink = document.getElementById('logo-link');

    // 1. Theme Toggle
    themeBtn?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });

    // 2. Mobile Menu Toggle
    const toggleMenu = (forceClose = false) => {
      const isOpening = menuOverlay?.classList.contains('hidden') && !forceClose;
      if (isOpening) {
        menuOverlay?.classList.remove('hidden');
        setTimeout(() => {
          menuContent?.classList.remove('opacity-0');
          openIcon?.classList.add('scale-0', 'opacity-0');
          closeIcon?.classList.remove('scale-0', 'opacity-0');
        }, 10);
      } else {
        menuContent?.classList.add('opacity-0');
        openIcon?.classList.remove('scale-0', 'opacity-0');
        closeIcon?.classList.add('scale-0', 'opacity-0');
        setTimeout(() => menuOverlay?.classList.add('hidden'), 300);
      }
    };

    menuBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleMenu();
    });

    // 3. Search Engine (Pagefind)
    let pagefind;
    const setupSearch = async (inputEl, resultsEl, listEl) => {
      inputEl?.addEventListener('focus', async () => {
        if (!pagefind) {
          try {
            pagefind = await import("/pagefind/pagefind.js");
            await pagefind.init();
          } catch (e) { console.error("Index missing. Run npm run build."); }
        }
      });

      inputEl?.addEventListener('input', async (e) => {
        const query = e.target.value;
        if (!pagefind || query.length < 2) {
          resultsEl?.classList.add('hidden');
          return;
        }

        const search = await pagefind.search(query);
        const results = await Promise.all(search.results.slice(0, 5).map(r => r.data()));

        if (results.length > 0) {
          listEl.innerHTML = results.map(res => `
            <a href="${res.url}" class="block p-3 hover:bg-accent transition-colors">
              <div class="font-bold text-primary text-xs uppercase tracking-tighter">${res.meta.title || 'Record'}</div>
              <div class="text-[11px] text-muted-foreground line-clamp-2 mt-1 leading-relaxed">
                ${res.excerpt}
              </div>
            </a>
          `).join('');
          resultsEl?.classList.remove('hidden');
        } else {
          listEl.innerHTML = '<div class="p-4 text-[11px] text-muted-foreground text-center">No matches in the lab.</div>';
          resultsEl?.classList.remove('hidden');
        }
      });
    };

    setupSearch(document.getElementById('nav-search'), document.getElementById('search-results'), document.getElementById('results-list'));
    setupSearch(document.getElementById('mobile-nav-search'), document.getElementById('mobile-search-results'), document.getElementById('mobile-results-list'));

    // 4. Global Cleanup
    document.addEventListener('click', (e) => {
      if (!e.target.closest('#nav-search') && !e.target.closest('#search-results')) document.getElementById('search-results')?.classList.add('hidden');
      if (!e.target.closest('#mobile-nav-search') && !e.target.closest('#mobile-search-results')) document.getElementById('mobile-search-results')?.classList.add('hidden');
    });

    logoLink?.addEventListener('click', (e) => {
      if (window.location.pathname === '/') {
        e.preventDefault();
        window.scrollTo({ top: 0, behavior: 'smooth' });
        toggleMenu(true);
      }
    });

    document.querySelectorAll('.mobile-link').forEach(link => {
      link.addEventListener('click', () => toggleMenu(true));
    });
  };

  initNavbar();
  document.addEventListener('astro:after-swap', initNavbar);
</script>
